{
  "name": "im-cbt",
  "version": "0.2.0",
  "description": "fluent ImageMagick 7 command line builder",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vladdeSV/im-cbt.git"
  },
  "keywords": [
    "imagemagick",
    "magick",
    "image",
    "command-line",
    "builder",
    "wand"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "source",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "test": "bun test",
    "lint": "biome check .",
    "prepublishOnly": "bun run build"
  },
  "engines": {
    "node": ">=22.12"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2"
  }
}
